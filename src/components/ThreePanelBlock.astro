---
import ComicPanel from './ComicPanel.astro';
import type { ComicPanelProps } from '../types/comicpanel';

interface Props {
  panels: ComicPanelProps[];
  widthClass?: string;
  heightClass?: string;
  orientation?: 'left' | 'right';
}

const {
  panels,
  widthClass = 'w-auto',
  heightClass = 'h-auto',
  orientation = 'right',
} = Astro.props;
---

<div
  class:list={[
    widthClass,
    heightClass,
    'md:max-h-screen mx-auto grid gap-4 px-4 pt-4 grid-cols-1 md:grid-cols-4 md:grid-rows-2',
  ]}
>
  {
    orientation === 'left' ? (
      <>
        <div class="w-full md:col-start-1 md:col-span-2 md:row-span-2">
          <ComicPanel {...panels[0]} />
        </div>
        <div class="w-full md:col-span-2 md:col-start-3">
          <ComicPanel {...panels[1]} />
        </div>
        <div class="w-full md:col-span-2 md:col-start-3">
          <ComicPanel {...panels[2]} />
        </div>
      </>
    ) : (
      <>
        <div class="w-full md:col-span-2 md:row-span-1">
          <ComicPanel {...panels[0]} />
        </div>
        <div class="w-full md:col-span-2 md:row-start-2">
          <ComicPanel {...panels[1]} />
        </div>
        <div class="w-full md:col-start-3 md:col-span-2 md:row-span-2">
          <ComicPanel {...panels[2]} />
        </div>
      </>
    )
  }
</div>
