---
import ComicPanel from './ComicPanel.astro';
import type { ComicPanelProps } from '../types/comicpanel';

interface Props {
  panels: ComicPanelProps[];
  widthClass?: string;
  heightClass?: string;
}

const { panels, widthClass = 'w-auto', heightClass = 'w-auto' } = Astro.props;
---

<div
  class:list={[
    widthClass,
    heightClass,
    'md:max-h-screen mx-auto grid gap-4 px-4 pt-4 grid-cols-1 md:grid-cols-2 md:grid-rows-3 lg:grid-cols-3 lg:grid-rows-1',
  ]}
>
  <div class="w-full">
    <ComicPanel {...panels[0]} />
  </div>
  <div class="w-full">
    <ComicPanel {...panels[1]} />
  </div>
  <div class="w-full md:row-span-2 md:col-span-2 lg:col-span-1 lg:row-span-1">
    <ComicPanel {...panels[2]} />
  </div>
</div>
